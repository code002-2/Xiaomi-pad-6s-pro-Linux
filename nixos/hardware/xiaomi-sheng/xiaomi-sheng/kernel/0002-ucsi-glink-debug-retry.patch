diff --git a/drivers/usb/typec/ucsi/ucsi_glink.c b/drivers/usb/typec/ucsi/ucsi_glink.c
index 11b3e24e3..520ad373d 100644
--- a/drivers/usb/typec/ucsi/ucsi_glink.c
+++ b/drivers/usb/typec/ucsi/ucsi_glink.c
@@ -4,6 +4,7 @@
  * Copyright (c) 2023, Linaro Ltd
  */
 #include <linux/auxiliary_bus.h>
+#include <linux/delay.h>
 #include <linux/module.h>
 #include <linux/mutex.h>
 #include <linux/of_device.h>
@@ -73,10 +74,11 @@ struct pmic_glink_ucsi {
 	struct mutex lock;	/* protects concurrent access to PMIC Glink interface */
 
 	struct work_struct notify_work;
-	struct work_struct register_work;
+	struct delayed_work register_work;
 	spinlock_t state_lock;
 	bool ucsi_registered;
 	bool pd_running;
+	int register_retries;
 
 	u8 read_buf[UCSI_BUF_V2_SIZE];
 };
@@ -121,7 +123,15 @@ out_unlock:
 
 static int pmic_glink_ucsi_read_version(struct ucsi *ucsi, u16 *version)
 {
-	return pmic_glink_ucsi_read(ucsi, UCSI_VERSION, version, sizeof(*version));
+	struct pmic_glink_ucsi *udata = ucsi_get_drvdata(ucsi);
+	int ret;
+
+	dev_dbg(udata->dev, "UCSI read_version: attempting to read version\n");
+	ret = pmic_glink_ucsi_read(ucsi, UCSI_VERSION, version, sizeof(*version));
+	dev_dbg(udata->dev,
+		 "UCSI read_version: ret=%d raw_version=0x%04x\n",
+		 ret, ret ? 0 : *version);
+	return ret;
 }
 
 static int pmic_glink_ucsi_read_cci(struct ucsi *ucsi, u32 *cci)
@@ -312,20 +322,55 @@ static void pmic_glink_ucsi_notify(struct work_struct *work)
 
 static void pmic_glink_ucsi_register(struct work_struct *work)
 {
-	struct pmic_glink_ucsi *ucsi = container_of(work, struct pmic_glink_ucsi, register_work);
+	struct pmic_glink_ucsi *ucsi = container_of(work, struct pmic_glink_ucsi,
+						    register_work.work);
 	unsigned long flags;
 	bool pd_running;
+	int ret;
 
 	spin_lock_irqsave(&ucsi->state_lock, flags);
 	pd_running = ucsi->pd_running;
 	spin_unlock_irqrestore(&ucsi->state_lock, flags);
 
+	dev_dbg(ucsi->dev,
+		 "UCSI register_work: pd_running=%d registered=%d retries=%d\n",
+		 pd_running, ucsi->ucsi_registered, ucsi->register_retries);
+
 	if (!ucsi->ucsi_registered && pd_running) {
-		ucsi_register(ucsi->ucsi);
-		ucsi->ucsi_registered = true;
+		dev_dbg(ucsi->dev, "UCSI calling ucsi_register...\n");
+		ret = ucsi_register(ucsi->ucsi);
+		dev_dbg(ucsi->dev, "UCSI ucsi_register returned %d\n", ret);
+
+		if (ret) {
+			dev_dbg(ucsi->dev,
+				"UCSI register failed: %d (attempt %d/60)\n",
+				ret, ucsi->register_retries + 1);
+			if (ucsi->register_retries < 60) {
+				ucsi->register_retries++;
+				dev_dbg(ucsi->dev, "UCSI scheduling register_work with 1000ms delay\n");
+				schedule_delayed_work(&ucsi->register_work, msecs_to_jiffies(1000));
+			} else {
+				dev_err(ucsi->dev, "UCSI registration failed completely after 60 retries\n");
+			}
+		} else {
+			dev_info(ucsi->dev, "UCSI registered successfully\n");
+			ucsi->ucsi_registered = true;
+			ucsi->register_retries = 0;
+		}
+	} else if (!ucsi->ucsi_registered && !pd_running) {
+		if (ucsi->register_retries < 60) {
+			dev_dbg(ucsi->dev, "PD service not running, retrying register_work (attempt %d/60) in 1s\n",
+				 ucsi->register_retries + 1);
+			ucsi->register_retries++;
+			schedule_delayed_work(&ucsi->register_work, msecs_to_jiffies(1000));
+		} else {
+			dev_err(ucsi->dev, "UCSI/PD service never became running after 60 retries\n");
+		}
 	} else if (ucsi->ucsi_registered && !pd_running) {
+		dev_info(ucsi->dev, "PD service stopped, unregistering UCSI\n");
 		ucsi_unregister(ucsi->ucsi);
 		ucsi->ucsi_registered = false;
+		ucsi->register_retries = 0;
 	}
 }
 
@@ -351,11 +396,18 @@ static void pmic_glink_ucsi_pdr_notify(void *priv, int state)
 {
 	struct pmic_glink_ucsi *ucsi = priv;
 	unsigned long flags;
+	bool old_pd_running;
 
 	spin_lock_irqsave(&ucsi->state_lock, flags);
+	old_pd_running = ucsi->pd_running;
 	ucsi->pd_running = (state == SERVREG_SERVICE_STATE_UP);
 	spin_unlock_irqrestore(&ucsi->state_lock, flags);
-	schedule_work(&ucsi->register_work);
+
+	dev_info(ucsi->dev, "PDR notify: state=%d, pd_running %d -> %d\n",
+		 state, old_pd_running, ucsi->pd_running);
+
+	dev_dbg(ucsi->dev, "PDR notify: scheduling register_work with 0 delay\n");
+	schedule_delayed_work(&ucsi->register_work, 0);
 }
 
 static void pmic_glink_ucsi_destroy(void *data)
@@ -390,6 +442,8 @@ static int pmic_glink_ucsi_probe(struct auxiliary_device *adev,
 	const struct of_device_id *match;
 	int ret;
 
+	dev_dbg(dev, "pmic_glink_ucsi_probe: starting\n");
+
 	ucsi = devm_kzalloc(dev, sizeof(*ucsi), GFP_KERNEL);
 	if (!ucsi)
 		return -ENOMEM;
@@ -398,15 +452,17 @@ static int pmic_glink_ucsi_probe(struct auxiliary_device *adev,
 	dev_set_drvdata(dev, ucsi);
 
 	INIT_WORK(&ucsi->notify_work, pmic_glink_ucsi_notify);
-	INIT_WORK(&ucsi->register_work, pmic_glink_ucsi_register);
+	INIT_DELAYED_WORK(&ucsi->register_work, pmic_glink_ucsi_register);
 	init_completion(&ucsi->read_ack);
 	init_completion(&ucsi->write_ack);
 	spin_lock_init(&ucsi->state_lock);
 	mutex_init(&ucsi->lock);
 
 	ucsi->ucsi = ucsi_create(dev, &pmic_glink_ucsi_ops);
-	if (IS_ERR(ucsi->ucsi))
+	if (IS_ERR(ucsi->ucsi)) {
+		dev_err(dev, "ucsi_create failed\n");
 		return PTR_ERR(ucsi->ucsi);
+	}
 
 	/* Make sure we destroy *after* pmic_glink unregister */
 	ret = devm_add_action_or_reset(dev, pmic_glink_ucsi_destroy, ucsi);
@@ -447,15 +503,23 @@ static int pmic_glink_ucsi_probe(struct auxiliary_device *adev,
 		ucsi->port_orientation[port] = desc;
 	}
 
+	dev_dbg(dev, "pmic_glink_ucsi_probe: calling devm_pmic_glink_client_alloc\n");
 	ucsi->client = devm_pmic_glink_client_alloc(dev, PMIC_GLINK_OWNER_USBC,
 						    pmic_glink_ucsi_callback,
 						    pmic_glink_ucsi_pdr_notify,
 						    ucsi);
-	if (IS_ERR(ucsi->client))
+	if (IS_ERR(ucsi->client)) {
+		dev_err(dev, "devm_pmic_glink_client_alloc failed: %ld\n", PTR_ERR(ucsi->client));
 		return PTR_ERR(ucsi->client);
+	}
 
+	dev_dbg(dev, "pmic_glink_ucsi_probe: calling pmic_glink_client_register\n");
 	pmic_glink_client_register(ucsi->client);
 
+	dev_dbg(dev, "pmic_glink_ucsi_probe: completed successfully, scheduling initial register_work\n");
+	/* Ensure register_work is scheduled at least once */
+	schedule_delayed_work(&ucsi->register_work, msecs_to_jiffies(1000));
+
 	return 0;
 }
 
