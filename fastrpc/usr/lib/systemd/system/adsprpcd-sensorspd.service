[Unit]
Description=sensorspd aDSP RPC daemon
After=dev-fastrpc\x2dadsp.device dev-fastrpc\x2dadsp\x2dsecure.device
ConditionPathExists=|/dev/fastrpc-adsp
ConditionPathExists=|/dev/fastrpc-adsp-secure

[Service]
Type=exec
ExecStart=/usr/sbin/adsprpcd sensorspd
Restart=on-failure
RestartSec=5

[Install]
WantedBy=iio-sensor-proxy.service