# Xiaomi Pad 6S Pro (sheng) - Accelerometer Mount Matrix Fix
#
# Fixes screen auto-rotation being offset by 90 degrees.
# The ICM4x6xx accelerometer is accessed via ADSP/SSC (fastrpc-adsp),
# not a standard IIO device, so we set ACCEL_MOUNT_MATRIX directly
# on the misc device that iio-sensor-proxy uses.
#
# Matrix format: x_x, x_y, x_z; y_x, y_y, y_z; z_x, z_y, z_z
# This swaps X and Y axes and inverts X, rotating sensor data by 90°
# to align with the panel's native orientation.
#
# To test/adjust:
#   1. monitor-sensor # observe "Accelerometer orientation changed: ..."
#   2. Hold tablet in desired "normal" landscape orientation
#   3. If orientation is wrong, adjust matrix below:
#      - Swap X/Y CW:   0, 1, 0; -1, 0, 0; 0, 0, -1  (90° CW / right)
#      - Swap X/Y CCW:  0, -1, 0; 1, 0, 0; 0, 0, -1  (90° CCW / left)
#      - No change:     1, 0, 0; 0, 1, 0; 0, 0, 1  (identity)
#      - Invert Z only: 1, 0, 0; 0, 1, 0; 0, 0, -1
#   4. Run: sudo udevadm trigger /dev/fastrpc-adsp
#   5. Run: sudo systemctl restart iio-sensor-proxy.service

ACTION=="remove", GOTO="sheng_accel_end"

SUBSYSTEM=="misc", KERNEL=="fastrpc-adsp*", \
  ENV{ACCEL_MOUNT_MATRIX}="0, 1, 0; -1, 0, 0; 0, 0, -1"

LABEL="sheng_accel_end"
