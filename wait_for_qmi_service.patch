diff -ura libssc/src/libssc-client.c libssc_p/src/libssc-client.c
--- libssc/src/libssc-client.c	2026-02-06 11:52:58.295547853 +0000
+++ libssc_p/src/libssc-client.c	2026-02-06 11:50:13.413216510 +0000
