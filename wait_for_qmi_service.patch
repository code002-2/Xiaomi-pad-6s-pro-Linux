 	/* Find QRTR node for SSC service */
-	for (GList *l = qrtr_bus_peek_nodes (priv->bus); l != NULL; l = l->next) {
-		node = l->data;
-
-		if (node && qrtr_node_lookup_port (node, QMI_SERVICE_SSC) >= 0) {
