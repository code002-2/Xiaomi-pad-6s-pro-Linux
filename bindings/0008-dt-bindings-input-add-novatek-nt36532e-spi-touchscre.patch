From 502e9e587431223bd4672dbd02234a5e3d5a8925 Mon Sep 17 00:00:00 2001
From: Tianyuan Jiang <code_0002@163.com>
Date: Wed, 22 Jul 2026 07:04:58 +0000
Subject: [PATCH 8/8] dt-bindings: input: add novatek,nt36532e-spi touchscreen

arm64: dts: qcom: sm8550-xiaomi-sheng: fix compatible format

Add binding for Novatek NT36532E SPI touchscreen controller.
Fix DTS compatible format violations:
- Remove pci17cb,1107 compatible from PCIe WiFi node (PCI devices
  auto-probe, no DT compatible needed)
- Change novatek,NVT-ts-spi to novatek,nt36532e-spi (lowercase)

Signed-off-by: Tianyuan Jiang <code_0002@163.com>
---
 .../touchscreen/novatek,nt36532e-spi.yaml     | 60 +++++++++++++++++++
 .../boot/dts/qcom/sm8550-xiaomi-sheng.dts     |  3 +-
 2 files changed, 61 insertions(+), 2 deletions(-)
 create mode 100644 Documentation/devicetree/bindings/input/touchscreen/novatek,nt36532e-spi.yaml

diff --git a/Documentation/devicetree/bindings/input/touchscreen/novatek,nt36532e-spi.yaml b/Documentation/devicetree/bindings/input/touchscreen/novatek,nt36532e-spi.yaml
new file mode 100644
index 000000000..bae1025eb
--- /dev/null
+++ b/Documentation/devicetree/bindings/input/touchscreen/novatek,nt36532e-spi.yaml
@@ -0,0 +1,60 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/input/touchscreen/novatek,nt36532e-spi.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Novatek NT36532E SPI Touchscreen
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  Novatek NT36532E touchscreen controller connected via SPI,
+  used on Xiaomi Pad 6S Pro (sheng).
+
+properties:
+  compatible:
+    const: novatek,nt36532e-spi
+
+  reg:
+    maxItems: 1
+
+  spi-max-frequency: true
+
+  novatek,irq-gpio:
+    maxItems: 1
+    description: GPIO for touch interrupt.
+
+  panel:
+    $ref: /schemas/types.yaml#/definitions/phandle
+    description: Phandle to the display panel.
+
+  firmware-name:
+    $ref: /schemas/types.yaml#/definitions/string
+    description: Firmware binary name for the touch controller.
+
+required:
+  - compatible
+  - reg
+  - novatek,irq-gpio
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    spi {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        touchscreen@0 {
+            compatible = "novatek,nt36532e-spi";
+            reg = <0>;
+            spi-max-frequency = <19200000>;
+            novatek,irq-gpio = <&tlmm 25 GPIO_ACTIVE_LOW>;
+            panel = <&display_panel>;
+            firmware-name = "novatek/novatek_nt36532_n81a_fw_csot.bin";
+        };
+    };
diff --git a/arch/arm64/boot/dts/qcom/sm8550-xiaomi-sheng.dts b/arch/arm64/boot/dts/qcom/sm8550-xiaomi-sheng.dts
index f883883d6..3bf48110e 100644
--- a/arch/arm64/boot/dts/qcom/sm8550-xiaomi-sheng.dts
+++ b/arch/arm64/boot/dts/qcom/sm8550-xiaomi-sheng.dts
@@ -1317,7 +1317,6 @@ &pcie0 {
 
 &pcieport0 {
 	wifi@0 {
-		compatible = "pci17cb,1107";
 		reg = <0x10000 0x0 0x0 0x0 0x0>;
 
 		vddrfacmn-supply = <&vreg_pmu_rfa_cmn>;
@@ -1476,7 +1475,7 @@ &spi4 {
 	status = "okay";
 
 	touchscreen@0 {
-		compatible = "novatek,NVT-ts-spi";
+		compatible = "novatek,nt36532e-spi";
 		reg = <0>;
 
 		spi-max-frequency = <19200000>;
-- 
2.39.5

