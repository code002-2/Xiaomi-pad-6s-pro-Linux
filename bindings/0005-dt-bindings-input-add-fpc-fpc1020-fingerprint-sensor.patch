From d1ac66daf3dd95fea008efb3dc9a0420621beb20 Mon Sep 17 00:00:00 2001
From: Tianyuan Jiang <code_0002@163.com>
Date: Wed, 22 Jul 2026 06:00:54 +0000
Subject: [PATCH 5/8] dt-bindings: input: add fpc,fpc1020 fingerprint sensor

Add binding for Fingerprint Cards FPC1020 capacitive fingerprint
sensor, used on Xiaomi Pad 6S Pro (sheng).

Signed-off-by: Tianyuan Jiang <code_0002@163.com>
---
 .../bindings/input/fpc,fpc1020.yaml           | 54 +++++++++++++++++++
 1 file changed, 54 insertions(+)
 create mode 100644 Documentation/devicetree/bindings/input/fpc,fpc1020.yaml

diff --git a/Documentation/devicetree/bindings/input/fpc,fpc1020.yaml b/Documentation/devicetree/bindings/input/fpc,fpc1020.yaml
new file mode 100644
index 000000000..8ccda3c02
--- /dev/null
+++ b/Documentation/devicetree/bindings/input/fpc,fpc1020.yaml
@@ -0,0 +1,54 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/input/fpc,fpc1020.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Fingerprint Cards FPC1020 Fingerprint Sensor
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The FPC1020 is a capacitive fingerprint sensor from Fingerprint Cards AB,
+  typically connected via SPI.
+
+properties:
+  compatible:
+    const: fpc,fpc1020
+
+  interrupts-extended:
+    maxItems: 1
+
+  irq-gpios:
+    maxItems: 1
+
+  fpc,gpio_rst:
+    $ref: /schemas/types.yaml#/definitions/phandle-array
+    description: GPIO connected to the RST pin.
+
+  fpc,gpio_irq:
+    $ref: /schemas/types.yaml#/definitions/phandle-array
+    description: GPIO connected to the IRQ pin.
+
+  fp_vdd_vreg-supply:
+    description: Power supply for the fingerprint sensor.
+
+required:
+  - compatible
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+    #include <dt-bindings/interrupt-controller/irq.h>
+
+    fingerprint-reader {
+        compatible = "fpc,fpc1020";
+        interrupts-extended = <&tlmm 40 IRQ_TYPE_EDGE_RISING>;
+        irq-gpios = <&tlmm 40 GPIO_ACTIVE_HIGH>;
+        fpc,gpio_rst = <&tlmm 41 GPIO_ACTIVE_HIGH>;
+        fpc,gpio_irq = <&tlmm 40 GPIO_ACTIVE_HIGH>;
+        fp_vdd_vreg-supply = <&vreg_l9b_3p3>;
+    };
-- 
2.39.5

