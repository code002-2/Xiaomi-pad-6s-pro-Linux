diff --git a/Documentation/devicetree/bindings/misc/nanosic,wn8030-sheng.yaml b/Documentation/devicetree/bindings/misc/nanosic,wn8030-sheng.yaml
new file mode 100644
index 000000000..0437c51ff
--- /dev/null
+++ b/Documentation/devicetree/bindings/misc/nanosic,wn8030-sheng.yaml
@@ -0,0 +1,68 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/misc/nanosic,wn8030-sheng.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Nanosic WN8030 Wireless Charging Controller
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The Nanosic WN8030 is a wireless charging receiver controller
+  connected via I2C, used on Xiaomi Pad 6S Pro (sheng).
+
+properties:
+  compatible:
+    const: nanosic,wn8030-sheng
+
+  reg:
+    maxItems: 1
+
+  interrupts:
+    maxItems: 1
+
+  reset-gpios:
+    maxItems: 1
+
+  sleep-gpios:
+    maxItems: 1
+
+  status-gpios:
+    maxItems: 1
+
+  vddio-supply:
+    description: I/O voltage supply.
+
+  dvdd-supply:
+    description: Digital core voltage supply.
+
+required:
+  - compatible
+  - reg
+  - interrupts
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+    #include <dt-bindings/interrupt-controller/irq.h>
+
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        charger@4c {
+            compatible = "nanosic,wn8030-sheng";
+            reg = <0x4c>;
+            interrupt-parent = <&tlmm>;
+            interrupts = <62 IRQ_TYPE_EDGE_RISING>;
+            reset-gpios = <&tlmm 58 GPIO_ACTIVE_LOW>;
+            sleep-gpios = <&tlmm 57 GPIO_ACTIVE_LOW>;
+            status-gpios = <&tlmm 56 GPIO_ACTIVE_HIGH>;
+            vddio-supply = <&vreg>;
+            dvdd-supply = <&vreg>;
+        };
+    };
diff --git a/Documentation/devicetree/bindings/usb/parade,ps5169.yaml b/Documentation/devicetree/bindings/usb/parade,ps5169.yaml
new file mode 100644
index 000000000..21df85167
--- /dev/null
+++ b/Documentation/devicetree/bindings/usb/parade,ps5169.yaml
@@ -0,0 +1,60 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/usb/parade,ps5169.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Parade PS5169 USB Type-C DP Alt Mode Retimer
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The Parade PS5169 is a USB Type-C DisplayPort alt mode retimer
+  and redriver, connected via I2C.
+
+properties:
+  compatible:
+    const: parade,ps5169
+
+  reg:
+    maxItems: 1
+
+  reset-gpios:
+    maxItems: 1
+
+  orientation-switch: true
+  retimer-switch: true
+
+  ports:
+    $ref: /schemas/graph.yaml#/properties/ports
+    properties:
+      port@0:
+        $ref: /schemas/graph.yaml#/properties/port
+        description: Output to SoC USB SS port.
+      port@1:
+        $ref: /schemas/graph.yaml#/properties/port
+        description: Input from PHY.
+
+required:
+  - compatible
+  - reg
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        typec-retimer@28 {
+            compatible = "parade,ps5169";
+            reg = <0x28>;
+            reset-gpios = <&tlmm 7 GPIO_ACTIVE_LOW>;
+            orientation-switch;
+            retimer-switch;
+        };
+    };
