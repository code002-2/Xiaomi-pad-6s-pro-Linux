diff --git a/Documentation/devicetree/bindings/display/panel/novatek,nt36532e.yaml b/Documentation/devicetree/bindings/display/panel/novatek,nt36532e.yaml
new file mode 100644
index 000000000..a1b2e9648
--- /dev/null
+++ b/Documentation/devicetree/bindings/display/panel/novatek,nt36532e.yaml
@@ -0,0 +1,79 @@
+# SPDX-License-Identifier: (GPL-2.0-only OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/display/panel/novatek,nt36532e.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Novatek NT36532E based DSI Display Panel
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The Novatek NT36532E is a DSI panel driver IC used in tablet
+  displays, such as the Xiaomi Pad 6S Pro (sheng) with dual DSI
+  interface.
+
+allOf:
+  - $ref: panel-common-dual.yaml#
+
+properties:
+  compatible:
+    items:
+      - const: xiaomi,sheng-nt36532e
+      - const: novatek,nt36532e
+
+  reg:
+    maxItems: 1
+
+  reset-gpios:
+    maxItems: 1
+
+  vddio-supply:
+    description: I/O voltage supply.
+
+  avdd-supply:
+    description: Positive analog voltage supply.
+
+  avee-supply:
+    description: Negative analog voltage supply.
+
+  backlight: true
+
+  ports:
+    $ref: /schemas/graph.yaml#/properties/ports
+    properties:
+      port@0:
+        $ref: /schemas/graph.yaml#/properties/port
+        description: DSI0 input port.
+      port@1:
+        $ref: /schemas/graph.yaml#/properties/port
+        description: DSI1 input port.
+
+required:
+  - compatible
+  - reg
+  - reset-gpios
+  - vddio-supply
+  - ports
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    dsi {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        panel@0 {
+            compatible = "xiaomi,sheng-nt36532e", "novatek,nt36532e";
+            reg = <0>;
+            reset-gpios = <&tlmm 133 GPIO_ACTIVE_LOW>;
+            vddio-supply = <&vreg>;
+            avdd-supply = <&vreg>;
+            avee-supply = <&vreg>;
+            backlight = <&backlight>;
+        };
+    };
diff --git a/Documentation/devicetree/bindings/media/i2c/giantec,gt9764.yaml b/Documentation/devicetree/bindings/media/i2c/giantec,gt9764.yaml
new file mode 100644
index 000000000..b86880e47
--- /dev/null
+++ b/Documentation/devicetree/bindings/media/i2c/giantec,gt9764.yaml
@@ -0,0 +1,67 @@
+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/media/i2c/giantec,gt9764.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Giantec GT9764 Camera Lens Actuator (VCM)
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The Giantec GT9764 is a voice coil motor (VCM) actuator for camera
+  lens focus control, connected via I2C.
+
+properties:
+  compatible:
+    const: giantec,gt9764
+
+  reg:
+    maxItems: 1
+
+  vin-supply:
+    description: Input voltage supply.
+
+  vdd-supply:
+    description: Core voltage supply.
+
+  dongwoon,clock-presc:
+    $ref: /schemas/types.yaml#/definitions/uint32
+    description: Clock prescaler for the AF driver.
+
+  dongwoon,aac-timing:
+    $ref: /schemas/types.yaml#/definitions/uint32
+    description: AAC timing setting.
+
+  dongwoon,initial-focus:
+    $ref: /schemas/types.yaml#/definitions/uint32
+    description: Initial focus position.
+
+  dongwoon,move-delay-us:
+    $ref: /schemas/types.yaml#/definitions/uint32
+    description: Move delay in microseconds.
+
+required:
+  - compatible
+  - reg
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        camera-lens@c {
+            compatible = "giantec,gt9764";
+            reg = <0x0c>;
+            vin-supply = <&vreg_l4b_1p8>;
+            vdd-supply = <&vreg_l7m_2p85>;
+            dongwoon,clock-presc = <0>;
+            dongwoon,aac-timing = <0x6a>;
+            dongwoon,initial-focus = <0x200>;
+            dongwoon,move-delay-us = <7000>;
+        };
+    };
diff --git a/Documentation/devicetree/bindings/media/i2c/ovti,ov02b1b.yaml b/Documentation/devicetree/bindings/media/i2c/ovti,ov02b1b.yaml
new file mode 100644
index 000000000..b97eae7a3
--- /dev/null
+++ b/Documentation/devicetree/bindings/media/i2c/ovti,ov02b1b.yaml
@@ -0,0 +1,75 @@
+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/media/i2c/ovti,ov02b1b.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Omnivision OV02B1B CMOS Sensor
+
+maintainers:
+  - Tianyuan Jiang <code_0002@163.com>
+
+description:
+  The Omnivision OV02B1B is a 2 megapixel CMOS image sensor.
+
+allOf:
+  - $ref: /schemas/media/video-interface-devices.yaml#
+
+properties:
+  compatible:
+    const: ovti,ov02b1b
+
+  reg:
+    maxItems: 1
+
+  clocks:
+    maxItems: 1
+
+  reset-gpios:
+    maxItems: 1
+
+  orientation: true
+  rotation: true
+
+  vddio-supply:
+    description: Digital I/O voltage supply.
+
+  avdd-supply:
+    description: Analog voltage supply.
+
+  port:
+    $ref: /schemas/media/video-interfaces.yaml#
+    unevaluatedProperties: false
+    properties:
+      endpoint:
+        $ref: /schemas/media/video-interfaces.yaml#
+        unevaluatedProperties: false
+        properties:
+          data-lanes: true
+          link-frequencies: true
+
+required:
+  - compatible
+  - reg
+  - clocks
+  - port
+
+unevaluatedProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/gpio/gpio.h>
+
+    i2c {
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        camera@3c {
+            compatible = "ovti,ov02b1b";
+            reg = <0x3c>;
+            clocks = <&camcc 0>;
+            reset-gpios = <&tlmm 117 GPIO_ACTIVE_LOW>;
+            vddio-supply = <&vreg>;
+            avdd-supply = <&vreg>;
+        };
+    };
